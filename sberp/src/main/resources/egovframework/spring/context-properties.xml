	        	<!-- AI (견적 AI 초안) : 내부 AI 서비스(ai-svc) 호출 -->
	        	<!-- 외부 LLM egress·API 키·모델은 ai-svc 컨테이너(.env)에서 관리 -->
	        	<!-- 운영 활성화 전 확인: ① ai-svc 기동 ② 내부 토큰 일치 ③ enabled=true -->
	        	<!-- [로컬 테스트] ai-svc 를 localhost:8000 으로 띄운 경우 -->
	        	<entry key="Globals.ai.enabled"   value="true" />
	        	<entry key="Globals.ai.baseUrl"   value="http://localhost:8000" />
