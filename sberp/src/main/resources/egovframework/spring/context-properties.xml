<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

	<bean name="propertiesService" class="egovframework.rte.fdl.property.impl.EgovPropertyServiceImpl" destroy-method="destroy">
		<property name="properties">
	        <map>
	        	<entry key="pageUnit" value="15"/>
	        	<entry key="pageSize" value="10"/>
	        	<entry key="posblAtchFileSize" value="5242880"/>
	        	
	        	<entry key="Globals.fileStorePath" value="webapps/sbfile/"/>
	        	<entry key="Globals.addedOptions" value="false"/>
	        	
	        	<!-- Nextcloud: 환경변수 / erp.properties / erp-local.properties (context-bean-env.xml) -->
	        	<entry key="Globals.nc.user" value="${GLOBALS_NC_USER}" />
	        	<entry key="Globals.nc.rootFolder" value="${GLOBALS_NC_ROOT_FOLDER}" />
	        	<entry key="Globals.nc.webdav.base" value="${GLOBALS_NC_WEBDAV_BASE}" />
	        	<entry key="Globals.nc.appPassword" value="${GLOBALS_NC_APP_PASSWORD}" />
	        	<entry key="Globals.nc.base" value="${GLOBALS_NC_BASE}" />
	        	<entry key="Globals.nc.shareToken" value="${GLOBALS_NC_SHARE_TOKEN}" />

	        	<entry key="img.url" value="/api/file/getImage.do?atchFileId=" />

	        	<!-- 성적서(report.do) 노출용 이미지 리사이즈 프록시 -->
	        	<!-- 원본은 그대로 저장하고, report.do 화면에서만 축소 이미지를 노출(브라우저 PDF 저장 용량 절감) -->
	        	<!-- imageMaxSize: 긴 변 최대 픽셀 / imageQuality: JPEG 품질(0~1, 낮을수록 용량 작음) -->
	        	<entry key="Globals.report.imageUrl" value="/api/file/reportImage.do" />
	        	<entry key="Globals.report.imageMaxSize" value="800" />
	        	<entry key="Globals.report.imageQuality" value="0.5" />

	        	<!-- ONLYOFFICE: NC 커넥터 앱 + Document Server URL 은 Nextcloud 관리 화면에서 설정 -->

	        	<!-- AI (견적 AI 초안) : 내부 AI 서비스(ai-svc) 호출 -->
	        	<!-- 외부 LLM egress·API 키·모델은 ai-svc 컨테이너(.env)에서 관리 -->
	        	<entry key="Globals.ai.enabled"   value="${GLOBALS_AI_ENABLED}" />
	        	<entry key="Globals.ai.baseUrl"   value="${GLOBALS_AI_BASE_URL}" />
	        	<entry key="Globals.ai.token"     value="${GLOBALS_AI_TOKEN}" />
	        	<entry key="Globals.ai.timeoutMs" value="${GLOBALS_AI_TIMEOUT_MS}" />
	        </map>
		</property>
	</bean>
	
</beans>
