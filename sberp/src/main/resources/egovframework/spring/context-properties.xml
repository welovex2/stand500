	        	<entry key="Globals.ai.enabled"   value="false" />
	        	<entry key="Globals.ai.baseUrl"   value="http://ai-svc:8000" />
	        	<entry key="Globals.ai.token"     value="change-me-internal-token" />
	        	<entry key="Globals.ai.timeoutMs" value="30000" />
	        	-->
